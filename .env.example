# ──────────────────────────────────────────────────────────────
# pgcli-boundary  –  environment configuration
# Copy this file to .env and fill in the values.
# .env is git-ignored and never committed.
# ──────────────────────────────────────────────────────────────

# Boundary controller URLs per environment with their OIDC auth method IDs.
# Format: label=https://hostname=amoidc_ID  (comma-separated, order determines UI order)
# Include only the environments that exist for your organisation – any subset is valid.
# If this variable is unset or empty the app starts with no environments configured.
BOUNDARY_ENVS=testing=https://boundary-controller.your-org-testing.example.com=amoidc_XXXXXXXXXXXX,production=https://boundary-controller.your-org.example.com=amoidc_XXXXXXXXXXXX

# Default environment selected on startup (must match one of the labels above).
# If unset, the first entry in BOUNDARY_ENVS is used.
BOUNDARY_DEFAULT_ENV=testing

BOUNDARY_USER=yourname@example.com
